{
  "expo": {
    "name": "MS Central",
    "slug": "ms-central",
    "version": "1.0.0",
    "description": "MS Central helps multiple sclerosis patients track their Coimbra Protocol vitamin D therapy — logging doses, scheduling pill reminders, and monitoring symptoms, all privately on-device.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mscentral.patient",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF7F4"
      },
      "package": "com.mscentral.patient",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MS Central uses your location to show local UV index and air quality for your protocol."
        }
      ]
    ]
  }
}
